# Copy this file to .env and fill in your values
# cp .env.example .env

# Optional: Apify token (not required — project uses Google News RSS)
# APIFY_API_TOKEN=your_token_here

# Search queries, comma-separated (Traditional Chinese)
MONITOR_QUERIES=台灣 政治 爭議,台灣 金融 市場

# RSS language settings (do not change unless fetching non-TW news)
LANGUAGE_CODE=zh-TW

# Output file paths (defaults shown)
# REPORT_PATH=daily_report.json
# HTML_REPORT_PATH=index.html
